generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ==================== USERS ====================
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String
  handle           String   @unique // @usuario.vrtx
  bio              String?  @db.VarChar(120)
  avatarUrl        String?
  phone            String?
  theme            Theme    @default(cyber)
  activeMode       Mode     @default(todo)
  
  // Social links (JSON)
  socialLinks      Json?    @default("{}")
  
  // Sport & wellness
  mainSport        String?
  sportLevel       String?
  
  // Medical emergency card
  bloodType        String?
  allergies        String[] @default([])
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?

  // Interests for recommendations
  interests        String[] @default([])

  // Spotify
  spotifyToken     String?
  spotifyRefresh   String?

  // Auth
  passwordHash     String?
  googleId         String?  @unique
  
  // Relations
  chips            Chip[]
  portfolio        PortfolioItem[]
  storeItems       StoreItem[]
  designs          Design[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("users")
}

// ==================== CHIPS ====================
model Chip {
  id             String   @id @default(uuid())
  chipId         String   @unique // UUID grabado en NFC
  serialNumber   String   @unique // VRTX-2026-001
  tier           Tier     @default(CORE)
  colorway       String   @default("Midnight Carbon")
  isAuthentic    Boolean  @default(true)
  nftTokenId     String?  // Solo LEGENDARY
  activatedAt    DateTime?
  
  // Relations
  owner          User?    @relation(fields: [ownerId], references: [id])
  ownerId        String?
  design         Design?  @relation(fields: [designId], references: [id])
  designId       String?
  scans          Scan[]

  createdAt      DateTime @default(now())

  @@map("chips")
}

// ==================== SCANS ====================
model Scan {
  id             String   @id @default(uuid())
  chip           Chip     @relation(fields: [chipId], references: [chipId])
  chipId         String
  latitude       Float?
  longitude      Float?
  city           String?
  country        String?
  modeShown      Mode     @default(todo)
  scannedAt      DateTime @default(now())

  @@index([chipId, scannedAt])
  @@map("scans")
}

// ==================== DESIGNS ====================
model Design {
  id             String   @id @default(uuid())
  name           String?
  collection     String?  // Drop 001, Drop 002...
  imageUrl       String
  promptUsed     String?  @db.Text
  estilo         String?
  elemento       String?
  colorDominante String?
  intensidad     String?
  editionNumber  Int?
  totalEdition   Int?

  // Relations
  owner          User?    @relation(fields: [ownerId], references: [id])
  ownerId        String?
  chips          Chip[]

  createdAt      DateTime @default(now())

  @@map("designs")
}

// ==================== PORTFOLIO ====================
model PortfolioItem {
  id             String   @id @default(uuid())
  title          String
  imageUrl       String?
  link           String?
  category       String   @default("Otro") // Diseño, Código, Video, Música, Arte, Otro
  
  owner          User     @relation(fields: [ownerId], references: [id])
  ownerId        String

  createdAt      DateTime @default(now())

  @@map("portfolio_items")
}

// ==================== STORE ====================
model StoreItem {
  id             String   @id @default(uuid())
  name           String
  description    String?
  price          Int      // COP
  imageUrl       String?
  paymentLink    String?
  active         Boolean  @default(true)

  owner          User     @relation(fields: [ownerId], references: [id])
  ownerId        String

  createdAt      DateTime @default(now())

  @@map("store_items")
}

// ==================== PREORDERS ====================
model Preorder {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String
  tier           Tier     @default(CORE)
  designId       String?
  status         String   @default("pending") // pending, confirmed, shipped, delivered
  notes          String?

  createdAt      DateTime @default(now())

  @@map("preorders")
}

// ==================== ENUMS ====================
enum Theme {
  cyber
  gold
  neon
  rose
  white
}

enum Mode {
  todo
  trabajo
  deporte
  parche
  negocio
}

enum Tier {
  CORE
  LINKED
  LEGENDARY
}
